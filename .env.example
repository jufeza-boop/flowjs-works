# =============================================================================
# flowjs-works — Development Environment Variables
# =============================================================================
# Copy this file to .env in each service directory and fill in values.
# The .env files are gitignored (see .gitignore: *.env) — never commit secrets.
#
# Quick start (all services from repo root):
#   cp .env.example services/engine/.env
#   cp .env.example services/audit-logger/.env
#   cp .env.example apps/designer/.env
#   docker compose up -d postgres nats
#   # Then start each service manually or via docker compose up
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

# Runtime mode. Controls security fallbacks:
#   "development" → allows missing ALLOWED_ORIGINS / SECRETS_AES_KEY (with WARNING)
#   Any other value (e.g. "production", "staging") → fatal if keys are missing
APP_ENV=development

# ---------------------------------------------------------------------------
# Engine service  (services/engine)
# ---------------------------------------------------------------------------

# NATS message bus URL (used for audit log publishing)
NATS_URL=nats://localhost:4222

# HTTP listen address for the engine REST API
HTTP_ADDR=:9090

# PostgreSQL connection string for the config/secrets DB (optional in dev)
DATABASE_URL=postgres://admin:flowjs_pass@localhost:5432/flowjs_config?sslmode=disable

# AES-256 key for encrypting stored secrets (must be ≥ 32 bytes in non-dev)
# In development a hardcoded dev key is used when this is absent — see ADR 0001.
# Generate a production value with: openssl rand -hex 32
SECRETS_AES_KEY=flowjs-dev-key-00000000000000000

# Maximum request duration for the engine HTTP server (go duration format)
REQUEST_TIMEOUT=60s

# Comma-separated list of allowed CORS origins.
# In development this defaults to http://localhost:5173 when left empty.
# REQUIRED in non-development environments — server refuses to start if unset.
ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Audit Logger service  (services/audit-logger)
# ---------------------------------------------------------------------------

# NATS message bus URL (used for consuming audit events)
# NATS_URL=nats://localhost:4222

# PostgreSQL DSN for the audit database
# POSTGRES_DSN=host=localhost port=5432 user=admin password=flowjs_pass dbname=flowjs_audit sslmode=disable

# HTTP listen address for the audit-logger query API
# HTTP_ADDR=:8080

# Comma-separated list of allowed CORS origins (same value as engine)
# ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Designer frontend  (apps/designer)
# ---------------------------------------------------------------------------

# Base URL of the engine REST API (used by the Vite dev proxy / fetch calls)
VITE_ENGINE_API_URL=http://localhost:9090

# Base URL of the audit-logger query API
VITE_AUDIT_API_URL=http://localhost:8080
